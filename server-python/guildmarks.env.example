GUILDMARKS_RATE_SECRET=replace-with-at-least-64-random-characters
GUILDMARKS_DB_PATH=/var/lib/guildmarks/guildmarks.sqlite3
GUILDMARKS_CATALOG_PATH=/etc/guildmarks/guilds.json
GUILDMARKS_RATE_CONFIG_PATH=/etc/guildmarks/rate-limits.json
GUILDMARKS_ALLOWED_HOSTS=capes.example.com
GUILDMARKS_REQUIRE_HTTPS=1
